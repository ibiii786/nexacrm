{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=@nexacrm/shared && cd apps/api && npx prisma generate --schema=prisma/schema.prisma && cd ../../apps/web && npm run build",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30,
      "includeFiles": "apps/api/prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
