# NexaCRM API Environment Variables
# Copy this file to apps/api/.env and fill in all values

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://nexacrm:nexacrm_dev@localhost:5432/nexacrm

# Cache & Queue (Redis)
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=generate-with-node-crypto-randomBytes-64-hex
JWT_REFRESH_SECRET=generate-with-node-crypto-randomBytes-64-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption Key for vault fields (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=change_me_to_32_byte_hex_string

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=NexaCRM <noreply@nexacrm.com>

# Cloudflare R2 (file storage - production only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nexacrm-uploads
R2_PUBLIC_URL=

# Super Admin (created by seed script)
SUPER_ADMIN_EMAIL=admin@nexacrm.com
SUPER_ADMIN_PASSWORD=NexaAdmin123!
SUPER_ADMIN_NAME=System Admin
