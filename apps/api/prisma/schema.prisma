generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar
  name          String    @db.VarChar
  passwordHash  String    @map("password_hash") @db.VarChar
  role          Role
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login") @db.Timestamptz
  previousLogin DateTime? @map("previous_login") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  createdBy     String?   @map("created_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz
  resetToken    String?   @map("reset_token") @db.VarChar
  resetTokenExp DateTime? @map("reset_token_exp") @db.Timestamptz

  creator      User?  @relation("UserCreator", fields: [createdBy], references: [id])
  createdUsers User[] @relation("UserCreator")

  sessions Session[]

  // Relations mapped for foreign keys below
  createdStatuses Status[]         @relation("StatusCreator")
  addedFields     Field[]          @relation("FieldAdder")
  createdOrders   Order[]          @relation("OrderCreator")
  uploadedFiles   Attachment[]     @relation("AttachmentUploader")
  orderAudits     OrderAuditLog[]
  auditLogs       AuditLog[]
  announcements   Announcement[]
  notifications   Notification[]
  updatedSettings Setting[]
  systemAudits    SystemAuditLog[]
  userSettings    UserSetting[]

  // IAM
  userPermissions    UserPermission[] @relation("UserPermissionAssignee")
  grantedPermissions UserPermission[] @relation("UserPermissionGrantor")

  // Payroll / FB
  createdEmployees Employee[]
  createdPayroll   PayrollPeriod[]
  createdCommissions Commission[]
  assignedFbAccs   FbAccount[]          @relation("FbAccountAssignee")
  createdFbAccs    FbAccount[]          @relation("FbAccountCreator")
  fbStatusChanges  FbAccountStatusLog[]

  @@map("users")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar
  familyId  String    @map("family_id") @db.Uuid
  ipAddress String?   @map("ip_address") @db.VarChar
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar
  description String?
  module      String? @db.VarChar

  userPermissions  UserPermission[]

  @@map("permissions")
}



model UserPermission {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  grantedBy    String?   @map("granted_by") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  isActive     Boolean   @default(true) @map("is_active")

  user       User       @relation("UserPermissionAssignee", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantor    User?      @relation("UserPermissionGrantor", fields: [grantedBy], references: [id])

  @@map("user_permissions")
}

model Status {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.VarChar
  color      String    @db.VarChar
  icon       String?   @db.VarChar
  isDefault  Boolean   @default(false) @map("is_default")
  isArchived Boolean   @default(false) @map("is_archived")
  position   Int
  createdBy  String?   @map("created_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  creator      User?         @relation("StatusCreator", fields: [createdBy], references: [id])
  orders       Order[]
  statusFields StatusField[]

  @@map("statuses")
}

model Field {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar
  label      String   @db.VarChar
  type       String   @db.VarChar
  isRequired Boolean  @default(false) @map("is_required")
  isVisible  Boolean  @default(true) @map("is_visible")
  isGlobal   Boolean  @default(true) @map("is_global")
  isArchived Boolean  @default(false) @map("is_archived")
  options    Json?    @db.JsonB
  position   Int
  isCopyable Boolean  @default(true) @map("is_copyable")
  copyPosition Int?   @map("copy_position")
  addedBy    String?  @map("added_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  adder        User?         @relation("FieldAdder", fields: [addedBy], references: [id])
  statusFields StatusField[]

  @@map("fields")
}

model StatusField {
  statusId String @map("status_id") @db.Uuid
  fieldId  String @map("field_id") @db.Uuid

  status Status @relation(fields: [statusId], references: [id], onDelete: Cascade)
  field  Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@id([statusId, fieldId])
  @@map("status_fields")
}

model Order {
  id           String    @id @default(uuid()) @db.Uuid
  orderNumber  String    @unique @map("order_number") @db.VarChar
  statusId     String    @map("status_id") @db.Uuid
  createdBy    String    @map("created_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  deliveryDate  DateTime? @map("delivery_date") @db.Date
  customFields  Json      @default("{}") @map("custom_fields") @db.JsonB
  notes         String?   @db.Text
  parsedRawText String?   @map("parsed_raw_text") @db.Text
  finalPaidAmount Decimal? @map("final_paid_amount") @db.Decimal(10, 2)
  finalPaidNote   String?  @map("final_paid_note") @db.Text

  status      Status          @relation(fields: [statusId], references: [id])
  creator     User            @relation("OrderCreator", fields: [createdBy], references: [id])
  attachments Attachment[]
  auditLogs   OrderAuditLog[]

  @@map("orders")
}

model OrderSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("order_sequences")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  filename   String   @db.VarChar
  filePath   String   @map("file_path") @db.VarChar
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type") @db.VarChar
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploader User? @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@map("attachments")
}

model OrderAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar
  fieldName String?  @map("field_name") @db.VarChar
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@map("order_audit_log")
}

model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  creator User? @relation(fields: [createdBy], references: [id])

  @@map("announcements")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar
  title     String   @db.VarChar
  body      String?  @db.Text
  link      String?  @db.VarChar
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar
  value     String   @db.Text
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  updater User? @relation(fields: [updatedBy], references: [id])

  @@map("settings")
}

model UserSetting {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String   @db.VarChar
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_settings")
}

model SystemAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar
  entityType String   @map("entity_type") @db.VarChar
  entityId   String?  @map("entity_id") @db.Uuid
  diff       Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("system_audit_log")
}

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar
  email           String?   @db.VarChar
  phone           String?   @db.VarChar
  role            String?   @db.VarChar
  joiningDate     DateTime? @map("joining_date") @db.Date
  baseSalary      Decimal?  @map("base_salary") @db.Decimal(10, 2)
  currency        String    @default("PKR") @db.VarChar
  paymentSchedule String?   @map("payment_schedule") @db.VarChar
  isActive        Boolean   @default(true) @map("is_active")
  createdBy       String?   @map("created_by") @db.Uuid

  creator        User?           @relation(fields: [createdBy], references: [id])
  payrollPeriods PayrollPeriod[]
  commissions       Commission[]

  @@map("employees")
}

model PayrollPeriod {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  periodStart DateTime  @map("period_start") @db.Date
  periodEnd   DateTime  @map("period_end") @db.Date
  grossSalary Decimal?  @map("gross_salary") @db.Decimal(10, 2)
  deductions  Json?     @default("{}") @db.JsonB
  netSalary   Decimal?  @map("net_salary") @db.Decimal(10, 2)
  status      String?   @default("PENDING") @db.VarChar
  paidAt      DateTime? @map("paid_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid

  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creator  User?     @relation(fields: [createdBy], references: [id])
  commissions Commission[]

  @@map("payroll_periods")
}

model Commission {
  id              String    @id @default(uuid()) @db.Uuid
  employeeId      String    @map("employee_id") @db.Uuid
  amount          Decimal?  @db.Decimal(10, 2)
  reason          String?   @db.Text
  date            DateTime? @db.Date
  payrollPeriodId String?   @map("payroll_period_id") @db.Uuid
  createdBy       String?   @map("created_by") @db.Uuid

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollPeriod PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id])
  creator       User?          @relation(fields: [createdBy], references: [id])

  @@map("commissions")
}

model FbAccount {
  id                 String    @id @default(uuid()) @db.Uuid
  displayName        String    @map("display_name") @db.VarChar
  linkedEmail        String?   @map("linked_email") @db.VarChar
  status             String    @db.VarChar
  creationDate       DateTime? @map("creation_date") @db.Date
  lastActivityDate   DateTime? @map("last_activity_date") @db.Date
  notes              String?   @db.Text
  assignedTo         String?   @map("assigned_to") @db.Uuid
  vaultNoteEncrypted String?   @map("vault_note_encrypted") @db.Text
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  assignee   User?                @relation("FbAccountAssignee", fields: [assignedTo], references: [id])
  creator    User?                @relation("FbAccountCreator", fields: [createdBy], references: [id])
  statusLogs FbAccountStatusLog[]

  @@map("fb_accounts")
}

model FbAccountStatusLog {
  id          String   @id @default(uuid()) @db.Uuid
  fbAccountId String   @map("fb_account_id") @db.Uuid
  oldStatus   String?  @map("old_status") @db.VarChar
  newStatus   String   @map("new_status") @db.VarChar
  changedBy   String?  @map("changed_by") @db.Uuid
  changedAt   DateTime @default(now()) @map("changed_at") @db.Timestamptz
  reason      String?  @db.Text

  fbAccount FbAccount @relation(fields: [fbAccountId], references: [id], onDelete: Cascade)
  changer   User?     @relation(fields: [changedBy], references: [id])

  @@map("fb_account_status_log")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String   @db.VarChar
  entity    String   @db.VarChar
  entityId  String?  @map("entity_id") @db.VarChar
  actorId   String?  @map("actor_id") @db.Uuid
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}
