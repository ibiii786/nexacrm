{
  "version": 2,
  "installCommand": "npm install && npm run build --workspace=@nexacrm/shared && cd apps/api && npx prisma generate --schema=prisma/schema.prisma",
  "builds": [
    {
      "src": "apps/api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "apps/api/prisma/**",
          "packages/shared/dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/apps/api/api/index.ts"
    }
  ]
}
